# ==================== REQUERIDO ====================
# Token del bot de Telegram (NO subir .env al repositorio)
TELEGRAM_BOT_TOKEN=tu_token_de_telegram_aqui

# ==================== PARA WEBHOOK (PRODUCCIÓN) ====================
# Nombre del host externo en Railway/Render
# Ejemplo: tu-app.onrender.com o tu-app.up.railway.app
RENDER_EXTERNAL_HOSTNAME=

# Puerto (Railway/Render asigna automáticamente)
PORT=8000

# ==================== OPCIONAL ====================
# Chat ID para notificaciones administrativas
ADMIN_CHAT_ID=

# URL del webhook (se construye automáticamente)
# WEBHOOK_URL=https://tu-app.onrender.com/webhook

# Ruta del webhook (por defecto /webhook)
# WEBHOOK_PATH=/webhook
